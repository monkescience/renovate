{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":automergeMajor"
  ],
  "platformAutomerge": true,
  "prHourlyLimit": 0,
  "minimumReleaseAge": "6 days",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "[A-Z0-9_]+:\\s*(?<currentValue>v?[^\\s#]+)\\s*#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.opentofu-version$/"],
      "matchStrings": ["(?<currentValue>.+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "opentofu/opentofu",
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["terraform-provider", "terraform-module"],
      "registryUrls": ["https://registry.opentofu.org"]
    },
    {
      "matchDepNames": ["hashicorp/terraform"],
      "enabled": false
    }
  ],
  "argocd": {
    "fileMatch": ["apps/.+\\.yaml$"]
  }
}
